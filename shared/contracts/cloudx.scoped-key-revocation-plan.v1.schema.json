{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.scoped-key-revocation-plan.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "status", "confirmation", "releaseVersion", "releaseArtifact",
    "transactionId", "unit", "gatewayRestartRequired", "automaticAction", "authorization"
  ],
  "properties": {
    "schema": {"const": "cloudx.scoped-key-revocation-plan.v1"},
    "status": {"const": "confirmation-required"},
    "confirmation": {"const": "RESTART cliproxy.service TO REVOKE PREVIOUS CLOUDX SCOPED KEY"},
    "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "releaseArtifact": {"type": "string", "pattern": "^/opt/cloudx/releases/[0-9]+\\.[0-9]+\\.[0-9]+/cloudx-cloud\\.pyz$"},
    "transactionId": {"type": "string", "pattern": "^[0-9]{8}T[0-9]{6}Z-[0-9a-f]{8}$"},
    "unit": {"const": "cliproxy.service"},
    "gatewayRestartRequired": {"const": true},
    "automaticAction": {"const": false},
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gatewayConfigWrite", "gatewayRestart", "previousCredentialRevocation",
        "credentialWrite", "otherKeyMutation"
      ],
      "properties": {
        "gatewayConfigWrite": {"const": false},
        "gatewayRestart": {"const": false},
        "previousCredentialRevocation": {"const": false},
        "credentialWrite": {"const": false},
        "otherKeyMutation": {"const": false}
      }
    }
  }
}
