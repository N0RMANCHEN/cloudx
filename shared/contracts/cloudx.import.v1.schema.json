{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.import.v1.schema.json",
  "title": "Cloudx import result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "requestId", "requestHash", "status", "dryRun", "written", "skipped", "errors"],
  "properties": {
    "schema": {"const": "cloudx.import.v1"},
    "requestId": {"type": "string", "minLength": 8},
    "requestHash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "status": {"enum": ["accepted", "partial", "rejected"]},
    "dryRun": {"type": "boolean"},
    "written": {"type": "integer", "minimum": 0},
    "skipped": {"type": "integer", "minimum": 0},
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "message": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
