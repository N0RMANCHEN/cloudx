+func TestCodexAgentIdentityRegistrationUsesGlobalProxy(t *testing.T) {
+	codexAgentIdentityTaskCache = sync.Map{}
+	auth, _ := testCodexAgentIdentityAuth(t, "runtime-global-proxy")
+	var registrations atomic.Int32
+	proxy := httptest.NewServer(http.HandlerFunc(func(writer http.ResponseWriter, request *http.Request) {
+		registrations.Add(1)
+		if request.URL.Host != "auth.invalid" {
+			t.Fatalf("registration host = %q, want auth.invalid", request.URL.Host)
+		}
+		if got := request.Header.Get("originator"); got != codexAgentIdentityOriginator {
+			t.Fatalf("originator = %q, want %q", got, codexAgentIdentityOriginator)
+		}
+		_ = json.NewEncoder(writer).Encode(map[string]string{"task_id": "task-proxy"})
+	}))
+	defer proxy.Close()
+	previousBaseURL := codexAgentIdentityAuthAPIBaseURL
+	codexAgentIdentityAuthAPIBaseURL = "http://auth.invalid/api/accounts"
+	defer func() { codexAgentIdentityAuthAPIBaseURL = previousBaseURL }()
+
+	cfg := &config.Config{SDKConfig: config.SDKConfig{ProxyURL: proxy.URL}}
+	if err := prepareCodexAgentIdentity(context.Background(), cfg, auth); err != nil {
+		t.Fatal(err)
+	}
+	if registrations.Load() != 1 {
+		t.Fatalf("registrations = %d, want 1", registrations.Load())
+	}
+}
