{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cloudx.local-cpa-capabilities.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "binary", "binarySha256", "runtimeVersion", "capabilities"],
  "properties": {
    "schema": {"const": "cloudx.local-cpa-capabilities.v1"},
    "binary": {"type": "string", "minLength": 1, "maxLength": 1024},
    "binarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "runtimeVersion": {"type": "string", "minLength": 1, "maxLength": 128},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"}
    }
  }
}
