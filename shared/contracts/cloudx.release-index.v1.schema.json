{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.release-index.v1.schema.json",
  "title": "Cloudx signed stable release index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "manifestSha256", "artifactRef", "publishedAt"],
  "properties": {
    "schema": {"const": "cloudx.release-index.v1"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "manifestSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "artifactRef": {"type": "string", "pattern": "^refs/heads/release-artifacts/v[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "publishedAt": {"type": "string", "format": "date-time"}
  }
}
