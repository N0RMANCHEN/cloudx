+package auth
+
+import (
+	"encoding/json"
+	"os"
+	"path/filepath"
+	"strings"
+	"sync"
+	"time"
+)
+
+const (
+	cloudxPoolObservationSchema = "cloudx.cpa-pool-observation.v1"
+	cloudxPoolObservationName   = "pool-state.json"
+	cloudxPoolWriteInterval     = 30 * time.Second
+)
+
+type cloudxPoolObservation struct {
+	Schema     string `json:"schema"`
+	State      string `json:"state"`
+	ObservedAt string `json:"observedAt"`
+}
+
+var cloudxPoolWriter = struct {
+	sync.Mutex
+	lastWrite time.Time
+}{}
+
+func cloudxWritePoolAvailableObservation() {
+	dir := strings.TrimSpace(os.Getenv("CLIPROXY_AUTH_SWEEP_DIR"))
+	if !filepath.IsAbs(dir) {
+		return
+	}
+	dir = filepath.Clean(dir)
+	if err := os.MkdirAll(dir, 0o700); err != nil {
+		return
+	}
+	info, err := os.Lstat(dir)
+	if err != nil || !info.IsDir() || info.Mode()&os.ModeSymlink != 0 {
+		return
+	}
+	if err = os.Chmod(dir, 0o700); err != nil {
+		return
+	}
+
+	now := time.Now().UTC()
+	cloudxPoolWriter.Lock()
+	if !cloudxPoolWriter.lastWrite.IsZero() && now.Sub(cloudxPoolWriter.lastWrite) < cloudxPoolWriteInterval {
+		cloudxPoolWriter.Unlock()
+		return
+	}
+	cloudxPoolWriter.lastWrite = now
+	cloudxPoolWriter.Unlock()
+
+	raw, err := json.Marshal(cloudxPoolObservation{
+		Schema: cloudxPoolObservationSchema, State: "available", ObservedAt: now.Format(time.RFC3339Nano),
+	})
+	if err != nil {
+		return
+	}
+	temporary, err := os.CreateTemp(dir, "."+cloudxPoolObservationName+".tmp-")
+	if err != nil {
+		return
+	}
+	temporaryPath := temporary.Name()
+	keep := false
+	defer func() {
+		_ = temporary.Close()
+		if !keep {
+			_ = os.Remove(temporaryPath)
+		}
+	}()
+	if err = temporary.Chmod(0o600); err != nil {
+		return
+	}
+	if _, err = temporary.Write(append(raw, '\n')); err != nil {
+		return
+	}
+	if err = temporary.Sync(); err != nil {
+		return
+	}
+	if err = temporary.Close(); err != nil {
+		return
+	}
+	if err = os.Rename(temporaryPath, filepath.Join(dir, cloudxPoolObservationName)); err != nil {
+		return
+	}
+	keep = true
+	if handle, openErr := os.Open(dir); openErr == nil {
+		_ = handle.Sync()
+		_ = handle.Close()
+	}
+}
