{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.stale-local-codexx-exec-retirement.v1.schema.json",
  "title": "Cloudx stale orphaned local codexx exec retirement receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "status", "decisionDigest", "processGroupsRetired", "parentProcessesRetired",
    "childProcessesRetired", "signal", "sigkillSent", "fileMutation", "serviceRestarted",
    "localCpaPid", "localCpaChanged"
  ],
  "properties": {
    "schema": {"const": "cloudx.stale-local-codexx-exec-retirement.v1"},
    "status": {"const": "retired"},
    "decisionDigest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "processGroupsRetired": {"type": "integer", "minimum": 1, "maximum": 8},
    "parentProcessesRetired": {"type": "integer", "minimum": 1, "maximum": 8},
    "childProcessesRetired": {"type": "integer", "minimum": 1, "maximum": 8},
    "signal": {"const": "SIGTERM"},
    "sigkillSent": {"const": false},
    "fileMutation": {"const": false},
    "serviceRestarted": {"const": false},
    "localCpaPid": {"type": "integer", "minimum": 1},
    "localCpaChanged": {"const": false}
  }
}
