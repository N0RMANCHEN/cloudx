[Unit]
Description=Rapidly calibrate CPA accounts after an aggregate auth-unavailable event
After=network-online.target mihomo.service cliproxy.service
Wants=network-online.target

[Service]
Type=oneshot
User=root
Group=root
UMask=0077
Environment=HTTP_PROXY=http://127.0.0.1:7890
Environment=HTTPS_PROXY=http://127.0.0.1:7890
Environment=CLOUDX_CPA_PROXY_URL=http://127.0.0.1:7890
Environment=CLOUDX_CPA_SWEEP_CONCURRENCY=32
ExecStart=/usr/bin/python3 /opt/cloudx/current/cloudx-cloud.pyz cpa-health --sweep-if-triggered
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
StateDirectory=cloudx/cpa-health
StateDirectoryMode=0700
ReadOnlyPaths=/opt/cloudx/releases
ReadWritePaths=/var/lib/cloudx/cpa-health /var/lib/codex-gateway/cliproxy-auth /var/lib/codex-gateway/cliproxy-auth-archive /var/lib/codex-gateway/cliproxy-auth-failures /var/lib/codex-gateway/cliproxy-auth-sweeps
InaccessiblePaths=/etc/phi /etc/msmtprc /etc/codex-quota-monitor.env /etc/codex-quota-monitor.gmail-app-password
PrivateDevices=true
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
