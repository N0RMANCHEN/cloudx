{
  "schema": "cloudx.phi-mesh-compatibility-profile.v1",
  "profileVersion": 1,
  "topology": {
    "schema": "cloudx.phi-mesh-topology.v1",
    "consumer": "phi_cloud",
    "directDeviceAccess": false
  },
  "protocol": {
    "min": 1,
    "max": 1
  },
  "contracts": {
    "handshake": {
      "schema": "cloudx.handshake.v1",
      "command": "cloudx-remote handshake --json",
      "requiredCapabilities": [
        "client-config.v1",
        "health.v1",
        "legacy-gateway.v1"
      ],
      "secretFree": true
    },
    "health": {
      "schema": "cloudx.health.v1",
      "command": "cloudx-remote health --json",
      "publishedPath": "/run/cloudx/health.json",
      "secretFree": true
    },
    "gateway": {
      "capability": "legacy-gateway.v1",
      "basePath": "/v1",
      "configurationSchema": "cloudx.client-config.v1"
    },
    "credential": {
      "configurationSchema": "cloudx.client-config.v1",
      "secretBearing": true,
      "profileContainsSecret": false,
      "lifecycle": "separate_scoped_credential_lifecycle"
    },
    "release": {
      "manifestSchema": "cloudx.release-manifest.v1",
      "indexSchema": "cloudx.release-index.v1",
      "statusSchema": "cloudx.release-status.v1",
      "statusCommand": "cloudx-remote release-status",
      "automaticActivation": false
    },
    "rollback": {
      "resultSchema": "cloudx.release-rollback.v1",
      "command": "cloudx-remote release-rollback --confirm <previous-version>",
      "currentAndPreviousRequired": true,
      "offlineRequired": true
    }
  },
  "compatibility": {
    "protocolOverlapRequired": true,
    "currentAndPreviousReleaseRequired": true,
    "independentReleaseOrdering": true,
    "synchronizedDeploymentRequired": false
  },
  "authorization": {
    "profileReadOnly": true,
    "profileGrantsCredentialAccess": false,
    "profileGrantsImport": false,
    "profileGrantsGatewayMutation": false,
    "profileGrantsReleaseMutation": false
  }
}
