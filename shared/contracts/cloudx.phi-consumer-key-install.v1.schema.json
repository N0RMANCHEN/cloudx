{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.phi-consumer-key-install.v1.schema.json",
  "title": "Cloudx Phi consumer key installation receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "releaseVersion",
    "unit",
    "credentialClass",
    "credentialMode",
    "credentialGroup",
    "oldPid",
    "newPid",
    "gatewayHttpStatus",
    "gatewayKeyCountBefore",
    "gatewayKeyCountAfter",
    "inotifyWatches",
    "cloudxClientCredentialUnchanged",
    "previousCredentialRetained",
    "previousCredentialRevoked",
    "phiServiceRestarted",
    "backup"
  ],
  "properties": {
    "schema": {"const": "cloudx.phi-consumer-key-install.v1"},
    "status": {"const": "installed"},
    "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "unit": {"const": "cliproxy.service"},
    "credentialClass": {"const": "scoped_phi_consumer"},
    "credentialMode": {"const": "0640"},
    "credentialGroup": {"const": "phi-cloudx-consumer"},
    "oldPid": {"type": "integer", "minimum": 0},
    "newPid": {"type": "integer", "minimum": 1},
    "gatewayHttpStatus": {"const": 200},
    "gatewayKeyCountBefore": {"type": "integer", "minimum": 0},
    "gatewayKeyCountAfter": {"type": "integer", "minimum": 1},
    "inotifyWatches": {"type": "integer", "minimum": 2},
    "cloudxClientCredentialUnchanged": {"const": true},
    "previousCredentialRetained": {"type": "boolean"},
    "previousCredentialRevoked": {"const": false},
    "phiServiceRestarted": {"const": false},
    "backup": {"type": "string", "pattern": "^/etc/cliproxy/backups/config\\.yaml\\.before-phi-consumer-[0-9]+$"}
  }
}
