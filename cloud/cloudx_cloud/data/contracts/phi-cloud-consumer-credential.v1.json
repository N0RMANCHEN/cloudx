{
  "schema": "cloudx.phi-cloud-consumer-credential.v1",
  "consumer": "phi_cloud",
  "credentialKind": "gateway_bearer",
  "audience": "cloudx_gateway",
  "purpose": "provider_inference",
  "representation": {
    "principal": "phi_cloud_service",
    "device": false,
    "task": false,
    "session": false
  },
  "scope": {
    "allowedOperations": [
      "gateway_inference"
    ],
    "deniedOperations": [
      "account_import",
      "cloudx_remote_admin",
      "gateway_configuration_mutation",
      "release_activation",
      "release_rollback",
      "release_staging",
      "device_identity_assertion"
    ]
  },
  "enforcement": {
    "gatewayBasePath": "/v1",
    "sshLogin": false,
    "cloudxRemote": false,
    "cloudxAuthRead": false,
    "cloudxReleaseRead": false
  },
  "storage": {
    "secretPath": "/etc/cloudx/consumers/phi-cloud/credential",
    "owner": "root",
    "group": "phi-cloudx-consumer",
    "mode": "0640",
    "repositoryAllowed": false,
    "releaseDirectoryAllowed": false
  },
  "lifecycle": {
    "revocable": true,
    "rotatable": true,
    "overlapDuringRotation": true,
    "rotationOrder": [
      "install_new_gateway_key",
      "write_new_consumer_secret",
      "canary_new_credential",
      "revoke_previous_gateway_key"
    ],
    "revocationOrder": [
      "disable_phi_consumer",
      "revoke_gateway_key",
      "remove_consumer_secret"
    ],
    "rollbackBeforePreviousRevocation": true,
    "operatorConfirmationRequired": true
  },
  "authorization": {
    "policyContainsSecret": false,
    "installAuthorized": false,
    "rotationAuthorized": false,
    "revocationAuthorized": false,
    "serviceRestartAuthorized": false
  }
}
