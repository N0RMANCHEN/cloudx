{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.stale-local-codexx-exec-decision.v1.schema.json",
  "title": "Cloudx stale orphaned local codexx exec retirement decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "status", "decisionDigest", "targetCount", "targetPids", "childPids",
    "minimumAgeSeconds", "stdioRevoked", "networkSockets", "minimumObservedCpuPercent",
    "localCpaPid", "localCpaChanged", "irreversibleProcessTerminationRequired"
  ],
  "properties": {
    "schema": {"const": "cloudx.stale-local-codexx-exec-decision.v1"},
    "status": {"const": "retirement-ready"},
    "decisionDigest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "targetCount": {"type": "integer", "minimum": 1, "maximum": 8},
    "targetPids": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
    "childPids": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
    "minimumAgeSeconds": {"const": 2592000},
    "stdioRevoked": {"const": true},
    "networkSockets": {"const": 0},
    "minimumObservedCpuPercent": {"type": "number", "minimum": 80, "maximum": 1000},
    "localCpaPid": {"type": "integer", "minimum": 1},
    "localCpaChanged": {"const": false},
    "irreversibleProcessTerminationRequired": {"const": true}
  }
}
