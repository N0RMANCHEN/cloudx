@@ -0,0 +1,169 @@
+package executor
+
+import (
+	"bytes"
+	"context"
+	"crypto/ed25519"
+	"crypto/rand"
+	"crypto/x509"
+	"encoding/base64"
+	"encoding/json"
+	"io"
+	"net/http"
+	"net/http/httptest"
+	"strings"
+	"sync"
+	"sync/atomic"
+	"testing"
+
+	cliproxyauth "github.com/router-for-me/CLIProxyAPI/v7/sdk/cliproxy/auth"
+)
+
+func testCodexAgentIdentityAuth(t *testing.T, runtimeID string) (*cliproxyauth.Auth, ed25519.PublicKey) {
+	t.Helper()
+	publicKey, privateKey, err := ed25519.GenerateKey(rand.Reader)
+	if err != nil {
+		t.Fatal(err)
+	}
+	der, err := x509.MarshalPKCS8PrivateKey(privateKey)
+	if err != nil {
+		t.Fatal(err)
+	}
+	return &cliproxyauth.Auth{Provider: "codex", Metadata: map[string]any{
+		"auth_mode":         "agentIdentity",
+		"agent_runtime_id":  runtimeID,
+		"agent_private_key": base64.StdEncoding.EncodeToString(der),
+		"account_id":        "acct-test",
+	}}, publicKey
+}
+
+func TestCodexAgentIdentityRegistersAndBuildsAssertion(t *testing.T) {
+	codexAgentIdentityTaskCache = sync.Map{}
+	auth, publicKey := testCodexAgentIdentityAuth(t, "runtime-test")
+	var registrations atomic.Int32
+	server := httptest.NewServer(http.HandlerFunc(func(writer http.ResponseWriter, request *http.Request) {
+		registrations.Add(1)
+		var payload map[string]string
+		if err := json.NewDecoder(request.Body).Decode(&payload); err != nil {
+			t.Fatal(err)
+		}
+		signature, err := base64.StdEncoding.DecodeString(payload["signature"])
+		if err != nil || !ed25519.Verify(
+			publicKey,
+			[]byte("runtime-test:"+payload["timestamp"]),
+			signature,
+		) {
+			t.Fatal("registration signature did not verify")
+		}
+		_ = json.NewEncoder(writer).Encode(map[string]string{"task_id": "task-test"})
+	}))
+	defer server.Close()
+	previousBaseURL := codexAgentIdentityAuthAPIBaseURL
+	codexAgentIdentityAuthAPIBaseURL = server.URL
+	defer func() { codexAgentIdentityAuthAPIBaseURL = previousBaseURL }()
+
+	if err := prepareCodexAgentIdentity(context.Background(), auth); err != nil {
+		t.Fatal(err)
+	}
+	if err := prepareCodexAgentIdentity(context.Background(), auth); err != nil {
+		t.Fatal(err)
+	}
+	if registrations.Load() != 1 {
+		t.Fatalf("registrations = %d, want 1", registrations.Load())
+	}
+	request := httptest.NewRequest(http.MethodPost, "https://chatgpt.com/backend-api/codex/responses", nil)
+	applyCodexHeaders(request, auth, "synthetic-token-must-not-be-used", true, nil)
+	authorization := request.Header.Get("Authorization")
+	if !strings.HasPrefix(authorization, "AgentAssertion ") {
+		t.Fatalf("Authorization = %q, want AgentAssertion", authorization)
+	}
+	envelopeBytes, err := base64.RawURLEncoding.DecodeString(
+		strings.TrimPrefix(authorization, "AgentAssertion "),
+	)
+	if err != nil {
+		t.Fatal(err)
+	}
+	var envelope map[string]string
+	if err := json.Unmarshal(envelopeBytes, &envelope); err != nil {
+		t.Fatal(err)
+	}
+	signature, err := base64.StdEncoding.DecodeString(envelope["signature"])
+	if err != nil || !ed25519.Verify(
+		publicKey,
+		[]byte("runtime-test:task-test:"+envelope["timestamp"]),
+		signature,
+	) {
+		t.Fatal("agent assertion signature did not verify")
+	}
+	if request.Header.Get("Chatgpt-Account-Id") != "acct-test" {
+		t.Fatal("ChatGPT account header is missing")
+	}
+}
+
+func TestCodexAgentIdentityIgnoresImportedTaskID(t *testing.T) {
+	codexAgentIdentityTaskCache = sync.Map{}
+	auth, _ := testCodexAgentIdentityAuth(t, "runtime-fresh")
+	auth.Metadata["task_id"] = "task-from-another-gateway"
+	key, err := codexAgentIdentityKeyFromAuth(auth)
+	if err != nil {
+		t.Fatal(err)
+	}
+	if key.taskID != "" {
+		t.Fatalf("task ID = %q, want fresh registration", key.taskID)
+	}
+}
+
+func TestCodexAgentIdentityRecoversInvalidTaskOnce(t *testing.T) {
+	codexAgentIdentityTaskCache = sync.Map{}
+	auth, _ := testCodexAgentIdentityAuth(t, "runtime-recovery")
+	var registrations atomic.Int32
+	registrationServer := httptest.NewServer(http.HandlerFunc(func(writer http.ResponseWriter, request *http.Request) {
+		index := registrations.Add(1)
+		_ = json.NewEncoder(writer).Encode(map[string]string{"task_id": "task-" + string(rune('0'+index))})
+	}))
+	defer registrationServer.Close()
+	previousBaseURL := codexAgentIdentityAuthAPIBaseURL
+	codexAgentIdentityAuthAPIBaseURL = registrationServer.URL
+	defer func() { codexAgentIdentityAuthAPIBaseURL = previousBaseURL }()
+	if err := prepareCodexAgentIdentity(context.Background(), auth); err != nil {
+		t.Fatal(err)
+	}
+	var calls atomic.Int32
+	upstream := httptest.NewServer(http.HandlerFunc(func(writer http.ResponseWriter, request *http.Request) {
+		_, _ = io.Copy(io.Discard, request.Body)
+		if calls.Add(1) == 1 {
+			writer.WriteHeader(http.StatusUnauthorized)
+			_, _ = writer.Write([]byte(`{"error":{"code":"invalid_task_id"}}`))
+			return
+		}
+		writer.WriteHeader(http.StatusOK)
+	}))
+	defer upstream.Close()
+	request, err := http.NewRequest(
+		http.MethodPost,
+		upstream.URL,
+		bytes.NewReader([]byte(`{"model":"test"}`)),
+	)
+	if err != nil {
+		t.Fatal(err)
+	}
+	applyCodexAgentIdentityHeaders(request, auth)
+	response, err := doCodexRequestWithAgentIdentityRecovery(
+		context.Background(),
+		upstream.Client(),
+		request,
+		auth,
+	)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer response.Body.Close()
+	if response.StatusCode != http.StatusOK || calls.Load() != 2 || registrations.Load() != 2 {
+		t.Fatalf(
+			"status=%d calls=%d registrations=%d",
+			response.StatusCode,
+			calls.Load(),
+			registrations.Load(),
+		)
+	}
+}
