diff --git a/sdk/cliproxy/auth/cloudx_failure_receipts.go b/sdk/cliproxy/auth/cloudx_failure_receipts.go
new file mode 100644
index 0000000000000000000000000000000000000000..79fe91d42b2b5430e4c48dbe6ecfcd625208351b
--- /dev/null
+++ b/sdk/cliproxy/auth/cloudx_failure_receipts.go
@@ -0,0 +1,301 @@
+package auth
+
+import (
+	"context"
+	"crypto/sha256"
+	"encoding/hex"
+	"encoding/json"
+	"errors"
+	"net/http"
+	"os"
+	"path/filepath"
+	"regexp"
+	"strings"
+	"sync"
+	"time"
+)
+
+const (
+	cloudxFailureReceiptSchema = "cloudx.cpa-auth-failure.v1"
+	cloudxFailureWindow        = 10 * time.Minute
+	cloudxMaxAuthFileBytes     = 4 * 1024 * 1024
+)
+
+var cloudxAuthFileNamePattern = regexp.MustCompile(`^[A-Za-z0-9][A-Za-z0-9._-]{0,254}\.json$`)
+
+type cloudxFailureEvidence struct {
+	authFile   string
+	authSHA256 string
+	reason     string
+	count      int
+	conclusive bool
+	observedAt time.Time
+}
+
+type cloudxFailureReceipt struct {
+	Schema               string `json:"schema"`
+	AuthFile             string `json:"authFile"`
+	AuthSHA256           string `json:"authSha256"`
+	Reason               string `json:"reason"`
+	FailureCount         int    `json:"failureCount"`
+	PermanentAuthFailure bool   `json:"permanentAuthFailure"`
+	WeeklyQuota          bool   `json:"weeklyQuota"`
+	ObservedAt           string `json:"observedAt"`
+}
+
+var cloudxFailureTracker = struct {
+	sync.Mutex
+	entries map[string]cloudxFailureEvidence
+}{entries: make(map[string]cloudxFailureEvidence)}
+
+func cloudxRecordResult(auth *Auth, result Result) {
+	if auth == nil {
+		return
+	}
+	if result.Success {
+		cloudxClearFailure(auth)
+		return
+	}
+	reason, conclusive := cloudxClassifyRequestFailure(result.Error)
+	if reason == "" {
+		return
+	}
+	if reason == "authentication_unauthorized" {
+		conclusive = !cloudxAuthHasRefreshCredential(auth)
+	}
+	cloudxObserveFailure(auth, reason, conclusive)
+}
+
+func cloudxRecordRefreshFailure(auth *Auth, err error) {
+	reason := cloudxClassifyRefreshFailure(err)
+	if reason == "" {
+		return
+	}
+	cloudxObserveFailure(auth, reason, true)
+}
+
+func cloudxClassifyRequestFailure(err *Error) (string, bool) {
+	if err == nil {
+		return "", false
+	}
+	raw := strings.ToLower(strings.TrimSpace(err.Code + " " + err.Message))
+	if cloudxLooksLikeQuota(raw, err.HTTPStatus) {
+		return "", false
+	}
+	if reason := cloudxExplicitPermanentReason(raw); reason != "" {
+		return reason, true
+	}
+	if err.HTTPStatus == http.StatusUnauthorized {
+		return "authentication_unauthorized", false
+	}
+	return "", false
+}
+
+func cloudxClassifyRefreshFailure(err error) string {
+	if err == nil || errors.Is(err, context.Canceled) {
+		return ""
+	}
+	raw := strings.ToLower(strings.TrimSpace(err.Error()))
+	status := cloudxErrorStatus(err)
+	if cloudxLooksLikeQuota(raw, status) {
+		return ""
+	}
+	if reason := cloudxExplicitPermanentReason(raw); reason != "" {
+		return reason
+	}
+	if status == http.StatusUnauthorized || strings.Contains(raw, "status 401") || strings.Contains(raw, "401 unauthorized") {
+		return "authentication_unauthorized"
+	}
+	return ""
+}
+
+func cloudxErrorStatus(err error) int {
+	type statusCoder interface{ StatusCode() int }
+	var value statusCoder
+	if errors.As(err, &value) && value != nil {
+		return value.StatusCode()
+	}
+	return 0
+}
+
+func cloudxLooksLikeQuota(raw string, status int) bool {
+	if status == http.StatusTooManyRequests {
+		return true
+	}
+	for _, marker := range []string{
+		"weekly limit", "weekly quota", "usage_limit", "usage limit",
+		"rate limit", "quota", "too many requests", "status 429", "429 ",
+	} {
+		if strings.Contains(raw, marker) {
+			return true
+		}
+	}
+	return false
+}
+
+func cloudxExplicitPermanentReason(raw string) string {
+	switch {
+	case strings.Contains(raw, "refresh_token_reused") || strings.Contains(raw, "refresh token reused"):
+		return "refresh_token_reused"
+	case strings.Contains(raw, "invalid_grant"):
+		return "refresh_invalid_grant"
+	case strings.Contains(raw, "refresh token revoked") || strings.Contains(raw, "refresh_token_revoked") || strings.Contains(raw, "token has been revoked"):
+		return "refresh_token_revoked"
+	case strings.Contains(raw, "account deactivated") || strings.Contains(raw, "account has been deactivated") || strings.Contains(raw, "account disabled") || strings.Contains(raw, "account has been disabled") || strings.Contains(raw, "account deleted"):
+		return "account_deactivated"
+	case strings.Contains(raw, "refresh token is required") || strings.Contains(raw, "missing refresh token"):
+		return "missing_token"
+	default:
+		return ""
+	}
+}
+
+func cloudxAuthHasRefreshCredential(auth *Auth) bool {
+	if auth == nil || auth.Metadata == nil {
+		return false
+	}
+	for _, key := range []string{"refresh_token", "refreshToken"} {
+		if value, ok := auth.Metadata[key].(string); ok && strings.TrimSpace(value) != "" {
+			return true
+		}
+	}
+	return false
+}
+
+func cloudxObserveFailure(auth *Auth, reason string, conclusive bool) {
+	authFile, digest, failureDir, ok := cloudxAuthSnapshot(auth)
+	if !ok {
+		return
+	}
+	now := time.Now().UTC()
+
+	cloudxFailureTracker.Lock()
+	defer cloudxFailureTracker.Unlock()
+	state, found := cloudxFailureTracker.entries[authFile]
+	if !found || state.authSHA256 != digest || now.Sub(state.observedAt) > cloudxFailureWindow {
+		state = cloudxFailureEvidence{authFile: authFile, authSHA256: digest}
+	}
+	state.count++
+	state.observedAt = now
+	if conclusive {
+		state.reason = reason
+		state.conclusive = true
+	} else if state.reason == "" {
+		state.reason = reason
+	}
+	cloudxFailureTracker.entries[authFile] = state
+	if state.count < 2 || !state.conclusive {
+		return
+	}
+	cloudxWriteFailureReceipt(failureDir, cloudxFailureReceipt{
+		Schema:               cloudxFailureReceiptSchema,
+		AuthFile:             authFile,
+		AuthSHA256:           digest,
+		Reason:               state.reason,
+		FailureCount:         state.count,
+		PermanentAuthFailure: true,
+		WeeklyQuota:          false,
+		ObservedAt:           now.Format(time.RFC3339Nano),
+	})
+}
+
+func cloudxClearFailure(auth *Auth) {
+	if auth == nil {
+		return
+	}
+	authFile := filepath.Base(strings.TrimSpace(auth.FileName))
+	if !cloudxAuthFileNamePattern.MatchString(authFile) {
+		return
+	}
+	cloudxFailureTracker.Lock()
+	delete(cloudxFailureTracker.entries, authFile)
+	cloudxFailureTracker.Unlock()
+	if failureDir, ok := cloudxFailureDirectory(); ok {
+		_ = os.Remove(filepath.Join(failureDir, authFile))
+	}
+}
+
+func cloudxAuthSnapshot(auth *Auth) (string, string, string, bool) {
+	if auth == nil {
+		return "", "", "", false
+	}
+	authFile := filepath.Base(strings.TrimSpace(auth.FileName))
+	if !cloudxAuthFileNamePattern.MatchString(authFile) {
+		return "", "", "", false
+	}
+	authDir := strings.TrimSpace(os.Getenv("CLIPROXY_AUTH_DIR"))
+	failureDir, ok := cloudxFailureDirectory()
+	if !ok || !filepath.IsAbs(authDir) || filepath.Clean(authDir) == filepath.Clean(failureDir) {
+		return "", "", "", false
+	}
+	authPath := filepath.Join(authDir, authFile)
+	info, err := os.Lstat(authPath)
+	if err != nil || !info.Mode().IsRegular() || info.Mode()&os.ModeSymlink != 0 || info.Size() > cloudxMaxAuthFileBytes {
+		return "", "", "", false
+	}
+	raw, err := os.ReadFile(authPath)
+	if err != nil || len(raw) > cloudxMaxAuthFileBytes {
+		return "", "", "", false
+	}
+	digest := sha256.Sum256(raw)
+	return authFile, hex.EncodeToString(digest[:]), failureDir, true
+}
+
+func cloudxFailureDirectory() (string, bool) {
+	dir := strings.TrimSpace(os.Getenv("CLIPROXY_AUTH_FAILURE_DIR"))
+	if !filepath.IsAbs(dir) {
+		return "", false
+	}
+	dir = filepath.Clean(dir)
+	if err := os.MkdirAll(dir, 0o700); err != nil {
+		return "", false
+	}
+	info, err := os.Lstat(dir)
+	if err != nil || !info.IsDir() || info.Mode()&os.ModeSymlink != 0 {
+		return "", false
+	}
+	if err := os.Chmod(dir, 0o700); err != nil {
+		return "", false
+	}
+	return dir, true
+}
+
+func cloudxWriteFailureReceipt(dir string, receipt cloudxFailureReceipt) {
+	raw, err := json.Marshal(receipt)
+	if err != nil {
+		return
+	}
+	temporary, err := os.CreateTemp(dir, "."+receipt.AuthFile+".tmp-")
+	if err != nil {
+		return
+	}
+	temporaryPath := temporary.Name()
+	keep := false
+	defer func() {
+		_ = temporary.Close()
+		if !keep {
+			_ = os.Remove(temporaryPath)
+		}
+	}()
+	if err = temporary.Chmod(0o600); err != nil {
+		return
+	}
+	if _, err = temporary.Write(append(raw, '\n')); err != nil {
+		return
+	}
+	if err = temporary.Sync(); err != nil {
+		return
+	}
+	if err = temporary.Close(); err != nil {
+		return
+	}
+	target := filepath.Join(dir, receipt.AuthFile)
+	if err = os.Rename(temporaryPath, target); err != nil {
+		return
+	}
+	keep = true
+	if handle, openErr := os.Open(dir); openErr == nil {
+		_ = handle.Sync()
+		_ = handle.Close()
+	}
+}
diff --git a/sdk/cliproxy/auth/cloudx_failure_receipts_test.go b/sdk/cliproxy/auth/cloudx_failure_receipts_test.go
new file mode 100644
index 0000000000000000000000000000000000000000..ad3440384918fda2fe503db45cceed8f6329a7c4
--- /dev/null
+++ b/sdk/cliproxy/auth/cloudx_failure_receipts_test.go
@@ -0,0 +1,100 @@
+package auth
+
+import (
+	"encoding/json"
+	"errors"
+	"net/http"
+	"os"
+	"path/filepath"
+	"testing"
+)
+
+func cloudxFailureFixture(t *testing.T, refreshToken bool) (*Auth, string) {
+	t.Helper()
+	root := t.TempDir()
+	authDir := filepath.Join(root, "auth")
+	failureDir := filepath.Join(root, "failures")
+	if err := os.Mkdir(authDir, 0o700); err != nil {
+		t.Fatal(err)
+	}
+	authFile := "codex-test.json"
+	if err := os.WriteFile(filepath.Join(authDir, authFile), []byte(`{"type":"codex","access_token":"secret"}`), 0o600); err != nil {
+		t.Fatal(err)
+	}
+	t.Setenv("CLIPROXY_AUTH_DIR", authDir)
+	t.Setenv("CLIPROXY_AUTH_FAILURE_DIR", failureDir)
+	cloudxFailureTracker.Lock()
+	cloudxFailureTracker.entries = make(map[string]cloudxFailureEvidence)
+	cloudxFailureTracker.Unlock()
+	auth := &Auth{FileName: authFile, Metadata: map[string]any{}}
+	if refreshToken {
+		auth.Metadata["refresh_token"] = "secret-refresh"
+	}
+	return auth, filepath.Join(failureDir, authFile)
+}
+
+func TestCloudxFailureReceiptRequiresPermanentNonQuotaEvidence(t *testing.T) {
+	auth, receiptPath := cloudxFailureFixture(t, true)
+	cloudxRecordResult(auth, Result{Error: &Error{HTTPStatus: http.StatusUnauthorized, Message: "expired token"}})
+	if _, err := os.Stat(receiptPath); !os.IsNotExist(err) {
+		t.Fatalf("receipt exists after provisional 401: %v", err)
+	}
+	cloudxRecordRefreshFailure(auth, errors.New(`token refresh failed with status 400: {"error":"invalid_grant"}`))
+	raw, err := os.ReadFile(receiptPath)
+	if err != nil {
+		t.Fatal(err)
+	}
+	var receipt cloudxFailureReceipt
+	if err := json.Unmarshal(raw, &receipt); err != nil {
+		t.Fatal(err)
+	}
+	if receipt.Schema != cloudxFailureReceiptSchema || receipt.Reason != "refresh_invalid_grant" || receipt.FailureCount != 2 {
+		t.Fatalf("unexpected receipt: %+v", receipt)
+	}
+	if !receipt.PermanentAuthFailure || receipt.WeeklyQuota {
+		t.Fatalf("unsafe receipt flags: %+v", receipt)
+	}
+}
+
+func TestCloudxFailureReceiptNeverTreatsWeeklyQuotaAsPermanent(t *testing.T) {
+	auth, receiptPath := cloudxFailureFixture(t, true)
+	for i := 0; i < 3; i++ {
+		cloudxRecordResult(auth, Result{Error: &Error{HTTPStatus: http.StatusTooManyRequests, Message: "weekly usage limit reached"}})
+		cloudxRecordRefreshFailure(auth, errors.New("weekly quota exhausted with status 429"))
+	}
+	if _, err := os.Stat(receiptPath); !os.IsNotExist(err) {
+		t.Fatalf("weekly quota created receipt: %v", err)
+	}
+}
+
+func TestCloudxFailureReceiptConfirmsRepeatedUnauthorizedWithoutRefresh(t *testing.T) {
+	auth, receiptPath := cloudxFailureFixture(t, false)
+	result := Result{Error: &Error{HTTPStatus: http.StatusUnauthorized, Message: "invalid or expired token"}}
+	cloudxRecordResult(auth, result)
+	cloudxRecordResult(auth, result)
+	var receipt cloudxFailureReceipt
+	raw, err := os.ReadFile(receiptPath)
+	if err != nil {
+		t.Fatal(err)
+	}
+	if err := json.Unmarshal(raw, &receipt); err != nil {
+		t.Fatal(err)
+	}
+	if receipt.Reason != "authentication_unauthorized" || receipt.FailureCount != 2 {
+		t.Fatalf("unexpected receipt: %+v", receipt)
+	}
+}
+
+func TestCloudxFailureReceiptClearsAfterSuccess(t *testing.T) {
+	auth, receiptPath := cloudxFailureFixture(t, false)
+	result := Result{Error: &Error{HTTPStatus: http.StatusUnauthorized, Message: "unauthorized"}}
+	cloudxRecordResult(auth, result)
+	cloudxRecordResult(auth, result)
+	if _, err := os.Stat(receiptPath); err != nil {
+		t.Fatal(err)
+	}
+	cloudxRecordResult(auth, Result{Success: true})
+	if _, err := os.Stat(receiptPath); !os.IsNotExist(err) {
+		t.Fatalf("receipt remains after success: %v", err)
+	}
+}
