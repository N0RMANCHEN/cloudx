{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.legacy-health-bridge-canary.v1.schema.json",
  "title": "Cloudx isolated legacy health bridge canary receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "releaseVersion",
    "releaseArtifact",
    "unit",
    "unitResult",
    "execMainStatus",
    "outputMode",
    "outputSha256",
    "canaryStarted",
    "canaryStoppedOnFailure",
    "temporaryOutputRemoved",
    "primaryServiceStarted",
    "primaryTimerEnabled",
    "legacyServiceStopped",
    "legacyTimerDisabled",
    "legacyOutputMutated",
    "releaseActivated",
    "legacyTimerActive",
    "legacyTimerEnabled"
  ],
  "properties": {
    "schema": {"const": "cloudx.legacy-health-bridge-canary.v1"},
    "status": {"const": "accepted"},
    "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "releaseArtifact": {"type": "string", "pattern": "^/opt/cloudx/releases/[0-9]+\\.[0-9]+\\.[0-9]+/cloudx-cloud\\.pyz$"},
    "unit": {"const": "cloudx-legacy-health-bridge-canary.service"},
    "unitResult": {"const": "success"},
    "execMainStatus": {"const": 0},
    "outputMode": {"const": "0644"},
    "outputSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "canaryStarted": {"const": true},
    "canaryStoppedOnFailure": {"const": false},
    "temporaryOutputRemoved": {"const": true},
    "primaryServiceStarted": {"const": false},
    "primaryTimerEnabled": {"const": false},
    "legacyServiceStopped": {"const": false},
    "legacyTimerDisabled": {"const": false},
    "legacyOutputMutated": {"const": false},
    "releaseActivated": {"const": false},
    "legacyTimerActive": {"const": true},
    "legacyTimerEnabled": {"const": true}
  }
}
