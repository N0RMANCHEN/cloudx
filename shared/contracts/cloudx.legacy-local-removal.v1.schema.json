{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.legacy-local-removal.v1.schema.json",
  "title": "Cloudx legacy local codex-plus quarantine receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "releaseVersion",
    "endpointScope",
    "backupId",
    "targetsQuarantined",
    "freshShellAccepted",
    "nativeImportDryRunAccepted",
    "officialCodexPreserved",
    "officialGitPreserved",
    "cloudxEntrypointsUnchanged",
    "shellHookUnchanged",
    "externalLocalCpaUnchanged",
    "accountProfilesRetained",
    "localCpaLaunchAgentRetained",
    "localCpaConfigurationRetained",
    "privateRecoveryBundleRetained",
    "manualRecoveryPrepared",
    "legacyRuntimeLive",
    "legacyLauncherLive",
    "recoveryEntrypointLive",
    "processTerminated",
    "serviceRestarted",
    "quarantineRetained"
  ],
  "properties": {
    "schema": {"const": "cloudx.legacy-local-removal.v1"},
    "status": {"const": "quarantined"},
    "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "endpointScope": {"const": "current_user_home"},
    "backupId": {"type": "string", "pattern": "^[0-9]{8}T[0-9]{6}Z$"},
    "targetsQuarantined": {"const": 3},
    "freshShellAccepted": {"const": true},
    "nativeImportDryRunAccepted": {"const": true},
    "officialCodexPreserved": {"const": true},
    "officialGitPreserved": {"const": true},
    "cloudxEntrypointsUnchanged": {"const": true},
    "shellHookUnchanged": {"const": true},
    "externalLocalCpaUnchanged": {"const": true},
    "accountProfilesRetained": {"const": true},
    "localCpaLaunchAgentRetained": {"const": true},
    "localCpaConfigurationRetained": {"const": true},
    "privateRecoveryBundleRetained": {"const": true},
    "manualRecoveryPrepared": {"const": true},
    "legacyRuntimeLive": {"const": false},
    "legacyLauncherLive": {"const": false},
    "recoveryEntrypointLive": {"const": false},
    "processTerminated": {"const": false},
    "serviceRestarted": {"const": false},
    "quarantineRetained": {"const": true}
  }
}
