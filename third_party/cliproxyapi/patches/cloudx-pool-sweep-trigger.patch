index 0000000000000000000000000000000000000000..3cdd07b5deb5fe69b23271a545bbf719e279224c
--- /dev/null
+++ b/sdk/api/handlers/cloudx_sweep_trigger.go
@@ -0,0 +1,115 @@
+package handlers
+
+import (
+	"encoding/json"
+	"os"
+	"path/filepath"
+	"strings"
+	"sync"
+	"time"
+)
+
+const (
+	cloudxSweepTriggerSchema = "cloudx.cpa-sweep-trigger.v1"
+	cloudxPoolStateSchema    = "cloudx.cpa-pool-observation.v1"
+	cloudxSweepWriteInterval = 30 * time.Second
+	cloudxSweepTriggerName   = "trigger.json"
+	cloudxPoolStateName      = "pool-state.json"
+)
+
+type cloudxSweepTrigger struct {
+	Schema     string `json:"schema"`
+	Reason     string `json:"reason"`
+	ObservedAt string `json:"observedAt"`
+}
+
+type cloudxPoolObservation struct {
+	Schema     string `json:"schema"`
+	State      string `json:"state"`
+	ObservedAt string `json:"observedAt"`
+}
+
+var cloudxSweepWriter = struct {
+	sync.Mutex
+	lastWrite time.Time
+}{}
+
+func cloudxWriteSweepTrigger() {
+	dir, ok := cloudxSweepDirectory()
+	if !ok {
+		return
+	}
+	now := time.Now().UTC()
+	cloudxSweepWriter.Lock()
+	if !cloudxSweepWriter.lastWrite.IsZero() && now.Sub(cloudxSweepWriter.lastWrite) < cloudxSweepWriteInterval {
+		cloudxSweepWriter.Unlock()
+		return
+	}
+	cloudxSweepWriter.lastWrite = now
+	cloudxSweepWriter.Unlock()
+
+	cloudxWritePrivateJSON(dir, cloudxPoolStateName, cloudxPoolObservation{
+		Schema: cloudxPoolStateSchema, State: "unavailable", ObservedAt: now.Format(time.RFC3339Nano),
+	})
+	cloudxWritePrivateJSON(dir, cloudxSweepTriggerName, cloudxSweepTrigger{
+		Schema: cloudxSweepTriggerSchema, Reason: "auth_unavailable", ObservedAt: now.Format(time.RFC3339Nano),
+	})
+}
+
+func cloudxSweepDirectory() (string, bool) {
+	dir := strings.TrimSpace(os.Getenv("CLIPROXY_AUTH_SWEEP_DIR"))
+	if !filepath.IsAbs(dir) {
+		return "", false
+	}
+	dir = filepath.Clean(dir)
+	if err := os.MkdirAll(dir, 0o700); err != nil {
+		return "", false
+	}
+	info, err := os.Lstat(dir)
+	if err != nil || !info.IsDir() || info.Mode()&os.ModeSymlink != 0 {
+		return "", false
+	}
+	if err := os.Chmod(dir, 0o700); err != nil {
+		return "", false
+	}
+	return dir, true
+}
+
+func cloudxWritePrivateJSON(dir, name string, value any) {
+	raw, err := json.Marshal(value)
+	if err != nil {
+		return
+	}
+	temporary, err := os.CreateTemp(dir, "."+name+".tmp-")
+	if err != nil {
+		return
+	}
+	temporaryPath := temporary.Name()
+	keep := false
+	defer func() {
+		_ = temporary.Close()
+		if !keep {
+			_ = os.Remove(temporaryPath)
+		}
+	}()
+	if err = temporary.Chmod(0o600); err != nil {
+		return
+	}
+	if _, err = temporary.Write(append(raw, '\n')); err != nil {
+		return
+	}
+	if err = temporary.Sync(); err != nil {
+		return
+	}
+	if err = temporary.Close(); err != nil {
+		return
+	}
+	if err = os.Rename(temporaryPath, filepath.Join(dir, name)); err != nil {
+		return
+	}
+	keep = true
+	if handle, openErr := os.Open(dir); openErr == nil {
+		_ = handle.Sync()
+		_ = handle.Close()
+	}
+}
