{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.scoped-key-revocation.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "status", "transactionId", "releaseVersion", "unit", "oldPid", "newPid",
    "gatewayKeyCountBefore", "gatewayKeyCountAfter", "newCredentialHttpStatus",
    "oldCredentialHttpStatus", "inotifyWatches", "configSha256Before", "configSha256After",
    "currentCredentialUnchanged", "previousCredentialRevoked", "otherGatewayKeysUnchanged",
    "backup"
  ],
  "properties": {
    "schema": {"const": "cloudx.scoped-key-revocation.v1"},
    "status": {"const": "revoked"},
    "transactionId": {"type": "string", "pattern": "^[0-9]{8}T[0-9]{6}Z-[0-9a-f]{8}$"},
    "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "unit": {"const": "cliproxy.service"},
    "oldPid": {"type": "integer", "minimum": 1},
    "newPid": {"type": "integer", "minimum": 1},
    "gatewayKeyCountBefore": {"type": "integer", "minimum": 2},
    "gatewayKeyCountAfter": {"type": "integer", "minimum": 1},
    "newCredentialHttpStatus": {"const": 200},
    "oldCredentialHttpStatus": {"const": 401},
    "inotifyWatches": {"type": "integer", "minimum": 2},
    "configSha256Before": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "configSha256After": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "currentCredentialUnchanged": {"const": true},
    "previousCredentialRevoked": {"const": true},
    "otherGatewayKeysUnchanged": {"const": true},
    "backup": {"type": "string"}
  }
}
