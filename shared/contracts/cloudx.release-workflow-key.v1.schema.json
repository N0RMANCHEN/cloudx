{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.release-workflow-key.v1.schema.json",
  "title": "Cloudx GitHub release workflow key synchronization receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "version",
    "repository",
    "branch",
    "workflow",
    "environment",
    "secret",
    "headCommit",
    "signerFingerprint",
    "secretExistedBefore",
    "environmentSecretUpdated",
    "workflowDispatched",
    "runId",
    "signedReleaseVerified",
    "releaseRefsUnchanged",
    "tagCreated",
    "artifactRefPublished",
    "stableMoved",
    "endpointStaged",
    "endpointActivated",
    "serviceRestarted"
  ],
  "properties": {
    "schema": {"const": "cloudx.release-workflow-key.v1"},
    "status": {"const": "canary-accepted"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "repository": {"const": "N0RMANCHEN/cloudx"},
    "branch": {"const": "main"},
    "workflow": {"const": "release.yml"},
    "environment": {"const": "release"},
    "secret": {"const": "CLOUDX_RELEASE_SIGNING_KEY"},
    "headCommit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "signerFingerprint": {"type": "string", "pattern": "^SHA256:[A-Za-z0-9+/]{43}$"},
    "secretExistedBefore": {"type": "boolean"},
    "environmentSecretUpdated": {"const": true},
    "workflowDispatched": {"const": true},
    "runId": {"type": "integer", "minimum": 1},
    "signedReleaseVerified": {"const": true},
    "releaseRefsUnchanged": {"const": true},
    "tagCreated": {"const": false},
    "artifactRefPublished": {"const": false},
    "stableMoved": {"const": false},
    "endpointStaged": {"const": false},
    "endpointActivated": {"const": false},
    "serviceRestarted": {"const": false}
  }
}
