{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.phi-consumer-key-plan.v1.schema.json",
  "title": "Cloudx Phi consumer key installation plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "confirmation",
    "releaseVersion",
    "releaseArtifact",
    "unit",
    "credentialClass",
    "credentialPath",
    "credentialGroup",
    "gatewayRestartRequired",
    "phiServiceRestartRequired",
    "preconditions",
    "automaticAction",
    "authorization"
  ],
  "properties": {
    "schema": {"const": "cloudx.phi-consumer-key-plan.v1"},
    "status": {"const": "confirmation-required"},
    "confirmation": {"const": "RESTART cliproxy.service FOR PHI CLOUDX CONSUMER KEY"},
    "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "releaseArtifact": {"type": "string", "pattern": "^/opt/cloudx/releases/[0-9]+\\.[0-9]+\\.[0-9]+/cloudx-cloud\\.pyz$"},
    "unit": {"const": "cliproxy.service"},
    "credentialClass": {"const": "scoped_phi_consumer"},
    "credentialPath": {"const": "/etc/cloudx/consumers/phi-cloud/credential"},
    "credentialGroup": {"const": "phi-cloudx-consumer"},
    "gatewayRestartRequired": {"const": true},
    "phiServiceRestartRequired": {"const": false},
    "preconditions": {
      "const": [
        "signed_cloud_artifact_staged",
        "phi_consumer_group_exists",
        "credential_directory_root_group_0750",
        "cloudx_client_credential_private"
      ]
    },
    "automaticAction": {"const": false},
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gatewayConfigWrite", "credentialWrite", "gatewayRestart", "phiServiceRestart", "previousCredentialRevocation"],
      "properties": {
        "gatewayConfigWrite": {"const": false},
        "credentialWrite": {"const": false},
        "gatewayRestart": {"const": false},
        "phiServiceRestart": {"const": false},
        "previousCredentialRevocation": {"const": false}
      }
    }
  }
}
