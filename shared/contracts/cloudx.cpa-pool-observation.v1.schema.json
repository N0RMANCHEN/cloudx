{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cloudx.cpa-pool-observation.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "state", "observedAt"],
