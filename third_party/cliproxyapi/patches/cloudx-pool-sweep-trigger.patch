@@ -0,0 +1,42 @@
+package auth
+
+import (
+	"encoding/json"
+	"os"
+	"path/filepath"
+	"strings"
+	"testing"
+	"time"
+)
+
+func TestCloudxModelCooldownExposesPoolUnavailableMarker(t *testing.T) {
+	err := newModelCooldownError("private-model", "private-provider", time.Minute)
+	if !err.CloudxPoolUnavailable() {
+		t.Fatal("model cooldown did not expose pool-unavailable marker")
+	}
+}
+
+func TestCloudxSuccessWritesIdentityFreePoolObservation(t *testing.T) {
+	dir := filepath.Join(t.TempDir(), "sweeps")
+	t.Setenv("CLIPROXY_AUTH_SWEEP_DIR", dir)
+	cloudxPoolWriter.Lock()
+	cloudxPoolWriter.lastWrite = cloudxPoolWriter.lastWrite.Add(-2 * cloudxPoolWriteInterval)
+	cloudxPoolWriter.Unlock()
+	auth := &Auth{ID: "private-auth-id", FileName: "private-auth.json"}
+	cloudxRecordResult(auth, Result{Success: true})
+
+	raw, err := os.ReadFile(filepath.Join(dir, cloudxPoolObservationName))
+	if err != nil {
+		t.Fatal(err)
+	}
+	var observation cloudxPoolObservation
+	if errJSON := json.Unmarshal(raw, &observation); errJSON != nil {
+		t.Fatal(errJSON)
+	}
+	if observation.Schema != cloudxPoolObservationSchema || observation.State != "available" || observation.ObservedAt == "" {
+		t.Fatalf("unexpected observation: %+v", observation)
+	}
+	if strings.Contains(string(raw), "private-auth") {
+		t.Fatalf("pool observation leaked auth identity: %s", raw)
+	}
+}
