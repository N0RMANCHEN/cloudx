diff --git a/internal/api/cloudx_request_policy.go b/internal/api/cloudx_request_policy.go
new file mode 100644
index 0000000000000000000000000000000000000000..b72415cb65444498c51cc6f9f8b8918d07b7d14f
--- /dev/null
+++ b/internal/api/cloudx_request_policy.go
@@ -0,0 +1,48 @@
+package api
+
+import (
+	"net/http"
+	"strings"
+
+	"github.com/gin-gonic/gin"
+)
+
+const cloudxMaxConcurrentAPIRequests = 2
+
+// cloudxRequestPolicyMiddleware caps all proxied inference traffic across every
+// credential at two in-flight requests. Requests wait for a slot and retain it
+// until the handler, including a streaming handler, returns. Local model-list,
+// health, OAuth, and management endpoints never consume a slot.
+func cloudxRequestPolicyMiddleware() gin.HandlerFunc {
+	slots := make(chan struct{}, cloudxMaxConcurrentAPIRequests)
+	return func(c *gin.Context) {
+		if c == nil || c.Request == nil || !cloudxProxiedAPIRequest(c.Request) {
+			c.Next()
+			return
+		}
+
+		select {
+		case slots <- struct{}{}:
+			defer func() { <-slots }()
+			c.Header("X-CPA-Max-Concurrent-API-Requests", "2")
+			c.Next()
+		case <-c.Request.Context().Done():
+			c.AbortWithStatus(499)
+		}
+	}
+}
+
+func cloudxProxiedAPIRequest(req *http.Request) bool {
+	if req == nil || req.URL == nil {
+		return false
+	}
+	path := req.URL.Path
+	if req.Method == http.MethodGet && (path == "/v1/models" || path == "/v1beta/models") {
+		return false
+	}
+	return path == "/v1" || strings.HasPrefix(path, "/v1/") ||
+		path == "/v1beta" || strings.HasPrefix(path, "/v1beta/") ||
+		path == "/openai/v1" || strings.HasPrefix(path, "/openai/v1/") ||
+		path == "/backend-api/codex" || strings.HasPrefix(path, "/backend-api/codex/") ||
+		path == "/v1internal:method"
+}
diff --git a/internal/api/cloudx_request_policy_test.go b/internal/api/cloudx_request_policy_test.go
new file mode 100644
index 0000000000000000000000000000000000000000..c4aa8b940b74570aa339d04f93970fa8689bb526
--- /dev/null
+++ b/internal/api/cloudx_request_policy_test.go
@@ -0,0 +1,96 @@
+package api
+
+import (
+	"net/http"
+	"net/http/httptest"
+	"sync"
+	"sync/atomic"
+	"testing"
+	"time"
+
+	"github.com/gin-gonic/gin"
+)
+
+func TestCloudxRequestPolicyCapsGlobalInferenceConcurrencyAtTwo(t *testing.T) {
+	gin.SetMode(gin.TestMode)
+	engine := gin.New()
+	engine.Use(cloudxRequestPolicyMiddleware())
+
+	release := make(chan struct{})
+	var active atomic.Int32
+	var maximum atomic.Int32
+	engine.POST("/v1/responses", func(c *gin.Context) {
+		current := active.Add(1)
+		for {
+			observed := maximum.Load()
+			if current <= observed || maximum.CompareAndSwap(observed, current) {
+				break
+			}
+		}
+		<-release
+		active.Add(-1)
+		c.Status(http.StatusOK)
+	})
+
+	const requests = 5
+	var wg sync.WaitGroup
+	wg.Add(requests)
+	for i := 0; i < requests; i++ {
+		go func() {
+			defer wg.Done()
+			recorder := httptest.NewRecorder()
+			req := httptest.NewRequest(http.MethodPost, "/v1/responses", nil)
+			engine.ServeHTTP(recorder, req)
+			if recorder.Code != http.StatusOK {
+				t.Errorf("status = %d, want 200", recorder.Code)
+			}
+			if got := recorder.Header().Get("X-CPA-Max-Concurrent-API-Requests"); got != "2" {
+				t.Errorf("policy header = %q, want 2", got)
+			}
+		}()
+	}
+
+	deadline := time.Now().Add(2 * time.Second)
+	for active.Load() != 2 && time.Now().Before(deadline) {
+		time.Sleep(time.Millisecond)
+	}
+	if got := active.Load(); got != 2 {
+		close(release)
+		wg.Wait()
+		t.Fatalf("active = %d, want 2", got)
+	}
+	if got := maximum.Load(); got != 2 {
+		close(release)
+		wg.Wait()
+		t.Fatalf("maximum = %d, want 2", got)
+	}
+
+	close(release)
+	wg.Wait()
+	if got := maximum.Load(); got != 2 {
+		t.Fatalf("maximum = %d, want 2", got)
+	}
+}
+
+func TestCloudxRequestPolicyExcludesLocalControlEndpoints(t *testing.T) {
+	cases := []struct {
+		method string
+		path   string
+		want   bool
+	}{
+		{http.MethodPost, "/v1/responses", true},
+		{http.MethodGet, "/backend-api/codex/responses", true},
+		{http.MethodPost, "/v1internal:method", true},
+		{http.MethodGet, "/v1/models", false},
+		{http.MethodGet, "/v1beta/models", false},
+		{http.MethodGet, "/healthz", false},
+		{http.MethodGet, "/v0/management/config", false},
+		{http.MethodGet, "/codex/callback", false},
+	}
+	for _, tc := range cases {
+		req := httptest.NewRequest(tc.method, tc.path, nil)
+		if got := cloudxProxiedAPIRequest(req); got != tc.want {
+			t.Errorf("%s %s = %v, want %v", tc.method, tc.path, got, tc.want)
+		}
+	}
+}
