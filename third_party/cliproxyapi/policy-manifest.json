{
  "schema": "cloudx.cliproxy-policy.v1",
  "policy": {
    "maxConcurrentAPIRequests": 2,
    "queueBehavior": "wait-until-slot-or-request-cancellation",
    "excludedEndpoints": [
      "health",
      "management",
      "oauth-callback",
      "local-model-list"
    ],
    "failureReceiptSchema": "cloudx.cpa-auth-failure.v1",
    "sweepTriggerSchema": "cloudx.cpa-sweep-trigger.v1",
    "poolObservationSchema": "cloudx.cpa-pool-observation.v1",
    "authDirectoryEnvironment": "CLIPROXY_AUTH_DIR",
    "failureDirectoryEnvironment": "CLIPROXY_AUTH_FAILURE_DIR",
    "sweepDirectoryEnvironment": "CLIPROXY_AUTH_SWEEP_DIR",
    "minimumFailureEvidence": 1,
    "permanentFailureArchivesImmediately": true,
    "provisionalFailureArchived": false,
    "periodicAccountProbe": false,
    "incidentProbeConcurrency": "adaptive-up-to-32",
    "aggregateSweepTriggerCodes": [
      "auth_unavailable",
      "model_cooldown"
    ],
    "weeklyQuotaArchived": false
  },
