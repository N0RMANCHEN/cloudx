+package handlers
+
+import (
+	"encoding/json"
+	"net/http"
+	"os"
+	"path/filepath"
+	"strings"
+	"testing"
+
+	coreauth "github.com/router-for-me/CLIProxyAPI/v7/sdk/cliproxy/auth"
+)
+
+func cloudxSweepFixture(t *testing.T) string {
+	t.Helper()
+	dir := filepath.Join(t.TempDir(), "sweeps")
+	t.Setenv("CLIPROXY_AUTH_SWEEP_DIR", dir)
+	cloudxSweepWriter.Lock()
+	cloudxSweepWriter.lastWrite = cloudxSweepWriter.lastWrite.Add(-2 * cloudxSweepWriteInterval)
+	cloudxSweepWriter.Unlock()
+	return dir
+}
+
+type cloudxPoolUnavailableFixture struct{}
+
+func (cloudxPoolUnavailableFixture) Error() string {
+	return "private model cooldown payload"
+}
+
+func (cloudxPoolUnavailableFixture) CloudxPoolUnavailable() bool {
+	return true
+}
+
+func TestCloudxAuthUnavailableWritesIdentityFreeSweepTrigger(t *testing.T) {
+	dir := cloudxSweepFixture(t)
+	err := &coreauth.Error{Code: "auth_unavailable", Message: "no auth available", HTTPStatus: http.StatusServiceUnavailable}
+	_ = enrichAuthSelectionError(err, []string{"private-provider"}, "private-model")
+
+	raw, readErr := os.ReadFile(filepath.Join(dir, cloudxSweepTriggerName))
+	if readErr != nil {
+		t.Fatal(readErr)
+	}
+	var trigger cloudxSweepTrigger
+	if errJSON := json.Unmarshal(raw, &trigger); errJSON != nil {
+		t.Fatal(errJSON)
+	}
+	if trigger.Schema != cloudxSweepTriggerSchema || trigger.Reason != "auth_unavailable" || trigger.ObservedAt == "" {
+		t.Fatalf("unexpected trigger: %+v", trigger)
+	}
+	if strings.Contains(string(raw), "private-provider") || strings.Contains(string(raw), "private-model") {
+		t.Fatalf("trigger leaked routing identity: %s", raw)
+	}
+
+	poolRaw, readPoolErr := os.ReadFile(filepath.Join(dir, cloudxPoolStateName))
+	if readPoolErr != nil {
+		t.Fatal(readPoolErr)
+	}
+	var pool cloudxPoolObservation
+	if errJSON := json.Unmarshal(poolRaw, &pool); errJSON != nil {
+		t.Fatal(errJSON)
+	}
+	if pool.Schema != cloudxPoolStateSchema || pool.State != "unavailable" {
+		t.Fatalf("unexpected pool observation: %+v", pool)
+	}
+}
+
+func TestCloudxModelCooldownWritesSweepTrigger(t *testing.T) {
+	dir := cloudxSweepFixture(t)
+	err := cloudxPoolUnavailableFixture{}
+	_ = enrichAuthSelectionError(err, nil, "private-model")
+	if _, statErr := os.Stat(filepath.Join(dir, cloudxSweepTriggerName)); statErr != nil {
+		t.Fatal(statErr)
+	}
+}
+
+func TestCloudxAuthNotFoundDoesNotTriggerSweep(t *testing.T) {
+	dir := cloudxSweepFixture(t)
+	err := &coreauth.Error{Code: "auth_not_found", Message: "no auth configured", HTTPStatus: http.StatusServiceUnavailable}
+	_ = enrichAuthSelectionError(err, nil, "private-model")
+	if _, statErr := os.Stat(filepath.Join(dir, cloudxSweepTriggerName)); !os.IsNotExist(statErr) {
+		t.Fatalf("auth_not_found created sweep trigger: %v", statErr)
+	}
+}
