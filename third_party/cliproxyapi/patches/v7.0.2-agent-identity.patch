+	cloudxAgentIdentityCapabilityHeader = "X-Cloudx-CPA-Capabilities"
+)
+
+func cloudxAgentIdentityCapabilityMiddleware() gin.HandlerFunc {
+	return func(c *gin.Context) {
+		c.Header(cloudxAgentIdentityCapabilityHeader, cloudxAgentIdentityCapability)
+		c.Next()
+	}
+}
