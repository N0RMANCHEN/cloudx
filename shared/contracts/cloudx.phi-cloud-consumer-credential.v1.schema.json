{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.phi-cloud-consumer-credential.v1.schema.json",
  "title": "Cloudx Phi cloud consumer credential policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "consumer",
    "credentialKind",
    "audience",
    "purpose",
    "representation",
    "scope",
    "enforcement",
    "storage",
    "lifecycle",
    "authorization"
  ],
  "properties": {
    "schema": {"const": "cloudx.phi-cloud-consumer-credential.v1"},
    "consumer": {"const": "phi_cloud"},
    "credentialKind": {"const": "gateway_bearer"},
    "audience": {"const": "cloudx_gateway"},
    "purpose": {"const": "provider_inference"},
    "representation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["principal", "device", "task", "session"],
      "properties": {
        "principal": {"const": "phi_cloud_service"},
        "device": {"const": false},
        "task": {"const": false},
        "session": {"const": false}
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedOperations", "deniedOperations"],
      "properties": {
        "allowedOperations": {
          "const": ["gateway_inference"]
        },
        "deniedOperations": {
          "type": "array",
          "minItems": 7,
          "uniqueItems": true,
          "items": {
            "enum": [
              "account_import",
              "cloudx_remote_admin",
              "gateway_configuration_mutation",
              "release_activation",
              "release_rollback",
              "release_staging",
              "device_identity_assertion"
            ]
          }
        }
      }
    },
    "enforcement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gatewayBasePath", "sshLogin", "cloudxRemote", "cloudxAuthRead", "cloudxReleaseRead"],
      "properties": {
        "gatewayBasePath": {"const": "/v1"},
        "sshLogin": {"const": false},
        "cloudxRemote": {"const": false},
        "cloudxAuthRead": {"const": false},
        "cloudxReleaseRead": {"const": false}
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["secretPath", "owner", "group", "mode", "repositoryAllowed", "releaseDirectoryAllowed"],
      "properties": {
        "secretPath": {"const": "/etc/cloudx/consumers/phi-cloud/credential"},
        "owner": {"const": "root"},
        "group": {"const": "phi-cloudx-consumer"},
        "mode": {"const": "0640"},
        "repositoryAllowed": {"const": false},
        "releaseDirectoryAllowed": {"const": false}
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revocable",
        "rotatable",
        "overlapDuringRotation",
        "rotationOrder",
        "revocationOrder",
        "rollbackBeforePreviousRevocation",
        "operatorConfirmationRequired"
      ],
      "properties": {
        "revocable": {"const": true},
        "rotatable": {"const": true},
        "overlapDuringRotation": {"const": true},
        "rotationOrder": {
          "const": [
            "install_new_gateway_key",
            "write_new_consumer_secret",
            "canary_new_credential",
            "revoke_previous_gateway_key"
          ]
        },
        "revocationOrder": {
          "const": [
            "disable_phi_consumer",
            "revoke_gateway_key",
            "remove_consumer_secret"
          ]
        },
        "rollbackBeforePreviousRevocation": {"const": true},
        "operatorConfirmationRequired": {"const": true}
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyContainsSecret",
        "installAuthorized",
        "rotationAuthorized",
        "revocationAuthorized",
        "serviceRestartAuthorized"
      ],
      "properties": {
        "policyContainsSecret": {"const": false},
        "installAuthorized": {"const": false},
        "rotationAuthorized": {"const": false},
        "revocationAuthorized": {"const": false},
        "serviceRestartAuthorized": {"const": false}
      }
    }
  }
}
