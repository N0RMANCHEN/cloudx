diff --git a/internal/runtime/executor/codex_agent_identity.go b/internal/runtime/executor/codex_agent_identity.go
new file mode 100644
index 0000000000000000000000000000000000000000..f79ebc9821dcef1ef5a1598f7561eb843ed954ab
--- /dev/null
+++ b/internal/runtime/executor/codex_agent_identity.go
@@ -0,0 +1,335 @@
+package executor
+
+import (
+	"bytes"
+	"context"
+	"crypto"
+	"crypto/ed25519"
+	"crypto/sha512"
+	"crypto/x509"
+	"encoding/base64"
+	"encoding/json"
+	"errors"
+	"fmt"
+	"io"
+	"net/http"
+	"net/url"
+	"strings"
+	"sync"
+	"time"
+
+	cliproxyauth "github.com/router-for-me/CLIProxyAPI/v7/sdk/cliproxy/auth"
+	"golang.org/x/crypto/curve25519"
+	"golang.org/x/crypto/nacl/box"
+)
+
+const (
+	codexAgentIdentityAuthMode       = "agentIdentity"
+	codexAgentIdentityRequestLimit   = 1024 * 1024
+	codexAgentIdentityRequestTimeout = 30 * time.Second
+)
+
+var (
+	codexAgentIdentityAuthAPIBaseURL = "https://auth.openai.com/api/accounts"
+	codexAgentIdentityTaskMu         sync.Mutex
+	codexAgentIdentityTaskCache      sync.Map
+)
+
+type codexAgentIdentityKey struct {
+	runtimeID  string
+	privateKey ed25519.PrivateKey
+	cacheKey   string
+	taskID     string
+}
+
+type codexAgentIdentityTaskResponse struct {
+	TaskID               string `json:"task_id"`
+	TaskIDCamel          string `json:"taskId"`
+	EncryptedTaskID      string `json:"encrypted_task_id"`
+	EncryptedTaskIDCamel string `json:"encryptedTaskId"`
+}
+
+func codexAgentIdentityMetadataString(auth *cliproxyauth.Auth, key string) string {
+	if auth == nil || auth.Metadata == nil {
+		return ""
+	}
+	value, _ := auth.Metadata[key].(string)
+	return strings.TrimSpace(value)
+}
+
+func isCodexAgentIdentity(auth *cliproxyauth.Auth) bool {
+	return strings.EqualFold(codexAgentIdentityMetadataString(auth, "auth_mode"), codexAgentIdentityAuthMode)
+}
+
+func codexAgentIdentityPrivateKey(auth *cliproxyauth.Auth) (ed25519.PrivateKey, error) {
+	raw := codexAgentIdentityMetadataString(auth, "agent_private_key")
+	if raw == "" {
+		return nil, errors.New("codex agent identity: private key is missing")
+	}
+	der, err := base64.StdEncoding.DecodeString(raw)
+	if err != nil {
+		return nil, errors.New("codex agent identity: private key is not valid base64")
+	}
+	parsed, err := x509.ParsePKCS8PrivateKey(der)
+	if err != nil {
+		return nil, errors.New("codex agent identity: private key is not valid PKCS#8")
+	}
+	privateKey, ok := parsed.(ed25519.PrivateKey)
+	if !ok || len(privateKey) != ed25519.PrivateKeySize {
+		return nil, errors.New("codex agent identity: private key is not Ed25519")
+	}
+	return privateKey, nil
+}
+
+func codexAgentIdentityKeyFromAuth(auth *cliproxyauth.Auth) (codexAgentIdentityKey, error) {
+	privateKey, err := codexAgentIdentityPrivateKey(auth)
+	if err != nil {
+		return codexAgentIdentityKey{}, err
+	}
+	runtimeID := codexAgentIdentityMetadataString(auth, "agent_runtime_id")
+	if runtimeID == "" {
+		return codexAgentIdentityKey{}, errors.New("codex agent identity: runtime id is missing")
+	}
+	publicKey, ok := privateKey.Public().(ed25519.PublicKey)
+	if !ok {
+		return codexAgentIdentityKey{}, errors.New("codex agent identity: public key is unavailable")
+	}
+	cacheKey := runtimeID + ":" + base64.RawStdEncoding.EncodeToString(publicKey)
+	taskID := ""
+	if cached, found := codexAgentIdentityTaskCache.Load(cacheKey); found {
+		taskID, _ = cached.(string)
+	}
+	return codexAgentIdentityKey{
+		runtimeID:  runtimeID,
+		privateKey: privateKey,
+		cacheKey:   cacheKey,
+		taskID:     strings.TrimSpace(taskID),
+	}, nil
+}
+
+func codexAgentIdentitySignRegistration(key codexAgentIdentityKey, now time.Time) (string, string, error) {
+	timestamp := now.UTC().Format(time.RFC3339)
+	signature, err := key.privateKey.Sign(nil, []byte(key.runtimeID+":"+timestamp), crypto.Hash(0))
+	if err != nil {
+		return "", "", errors.New("codex agent identity: failed to sign task registration")
+	}
+	return timestamp, base64.StdEncoding.EncodeToString(signature), nil
+}
+
+func codexAgentIdentityAssertion(auth *cliproxyauth.Auth, now time.Time) (string, bool) {
+	if !isCodexAgentIdentity(auth) {
+		return "", false
+	}
+	key, err := codexAgentIdentityKeyFromAuth(auth)
+	if err != nil || key.taskID == "" {
+		return "", false
+	}
+	timestamp := now.UTC().Format(time.RFC3339)
+	signature, err := key.privateKey.Sign(
+		nil,
+		[]byte(key.runtimeID+":"+key.taskID+":"+timestamp),
+		crypto.Hash(0),
+	)
+	if err != nil {
+		return "", false
+	}
+	envelope, err := json.Marshal(map[string]string{
+		"agent_runtime_id": key.runtimeID,
+		"task_id":          key.taskID,
+		"timestamp":        timestamp,
+		"signature":        base64.StdEncoding.EncodeToString(signature),
+	})
+	if err != nil {
+		return "", false
+	}
+	return "AgentAssertion " + base64.RawURLEncoding.EncodeToString(envelope), true
+}
+
+func codexAgentIdentityDecryptTaskID(key codexAgentIdentityKey, encoded string) (string, error) {
+	ciphertext, err := base64.StdEncoding.DecodeString(strings.TrimSpace(encoded))
+	if err != nil {
+		return "", errors.New("codex agent identity: encrypted task id is not valid base64")
+	}
+	digest := sha512.Sum512(key.privateKey.Seed())
+	var curvePrivate [32]byte
+	copy(curvePrivate[:], digest[:32])
+	curvePrivate[0] &= 248
+	curvePrivate[31] &= 127
+	curvePrivate[31] |= 64
+	curvePublicBytes, err := curve25519.X25519(curvePrivate[:], curve25519.Basepoint)
+	if err != nil {
+		return "", errors.New("codex agent identity: failed to derive decryption key")
+	}
+	var curvePublic [32]byte
+	copy(curvePublic[:], curvePublicBytes)
+	plaintext, ok := box.OpenAnonymous(nil, ciphertext, &curvePublic, &curvePrivate)
+	if !ok {
+		return "", errors.New("codex agent identity: failed to decrypt task id")
+	}
+	taskID := strings.TrimSpace(string(plaintext))
+	if taskID == "" {
+		return "", errors.New("codex agent identity: decrypted task id is empty")
+	}
+	return taskID, nil
+}
+
+func codexAgentIdentityHTTPClient(auth *cliproxyauth.Auth) (*http.Client, error) {
+	transport := http.DefaultTransport.(*http.Transport).Clone()
+	if auth != nil && strings.TrimSpace(auth.ProxyURL) != "" {
+		proxyURL, err := url.Parse(strings.TrimSpace(auth.ProxyURL))
+		if err != nil {
+			return nil, errors.New("codex agent identity: proxy URL is invalid")
+		}
+		transport.Proxy = http.ProxyURL(proxyURL)
+	}
+	return &http.Client{Transport: transport, Timeout: codexAgentIdentityRequestTimeout}, nil
+}
+
+func codexAgentIdentityRegisterTask(
+	ctx context.Context,
+	auth *cliproxyauth.Auth,
+	key codexAgentIdentityKey,
+) (string, error) {
+	timestamp, signature, err := codexAgentIdentitySignRegistration(key, time.Now())
+	if err != nil {
+		return "", err
+	}
+	body, err := json.Marshal(map[string]string{"timestamp": timestamp, "signature": signature})
+	if err != nil {
+		return "", errors.New("codex agent identity: failed to serialize task registration")
+	}
+	registrationURL := strings.TrimRight(codexAgentIdentityAuthAPIBaseURL, "/") +
+		"/v1/agent/" + url.PathEscape(key.runtimeID) + "/task/register"
+	request, err := http.NewRequestWithContext(ctx, http.MethodPost, registrationURL, bytes.NewReader(body))
+	if err != nil {
+		return "", errors.New("codex agent identity: failed to create task registration request")
+	}
+	request.Header.Set("Content-Type", "application/json")
+	request.Header.Set("Accept", "application/json")
+	client, err := codexAgentIdentityHTTPClient(auth)
+	if err != nil {
+		return "", err
+	}
+	response, err := client.Do(request)
+	if err != nil {
+		return "", errors.New("codex agent identity: task registration request failed")
+	}
+	defer response.Body.Close()
+	if response.StatusCode < http.StatusOK || response.StatusCode >= http.StatusMultipleChoices {
+		return "", fmt.Errorf("codex agent identity: task registration returned status %d", response.StatusCode)
+	}
+	var result codexAgentIdentityTaskResponse
+	if err := json.NewDecoder(io.LimitReader(response.Body, 64*1024)).Decode(&result); err != nil {
+		return "", errors.New("codex agent identity: task registration response is invalid")
+	}
+	for _, taskID := range []string{result.TaskID, result.TaskIDCamel} {
+		if strings.TrimSpace(taskID) != "" {
+			return strings.TrimSpace(taskID), nil
+		}
+	}
+	encrypted := strings.TrimSpace(result.EncryptedTaskID)
+	if encrypted == "" {
+		encrypted = strings.TrimSpace(result.EncryptedTaskIDCamel)
+	}
+	if encrypted == "" {
+		return "", errors.New("codex agent identity: task registration response omitted task id")
+	}
+	return codexAgentIdentityDecryptTaskID(key, encrypted)
+}
+
+func codexAgentIdentityRegisterAndCache(ctx context.Context, auth *cliproxyauth.Auth, force bool) error {
+	key, err := codexAgentIdentityKeyFromAuth(auth)
+	if err != nil {
+		return err
+	}
+	if !force && key.taskID != "" {
+		return nil
+	}
+	codexAgentIdentityTaskMu.Lock()
+	defer codexAgentIdentityTaskMu.Unlock()
+	key, err = codexAgentIdentityKeyFromAuth(auth)
+	if err != nil {
+		return err
+	}
+	if !force && key.taskID != "" {
+		return nil
+	}
+	taskID, err := codexAgentIdentityRegisterTask(ctx, auth, key)
+	if err != nil {
+		return err
+	}
+	codexAgentIdentityTaskCache.Store(key.cacheKey, taskID)
+	return nil
+}
+
+func prepareCodexAgentIdentity(ctx context.Context, auth *cliproxyauth.Auth) error {
+	if !isCodexAgentIdentity(auth) {
+		return nil
+	}
+	return codexAgentIdentityRegisterAndCache(ctx, auth, false)
+}
+
+func applyCodexAgentIdentityHeaders(request *http.Request, auth *cliproxyauth.Auth) {
+	if request == nil || !isCodexAgentIdentity(auth) {
+		return
+	}
+	if assertion, ok := codexAgentIdentityAssertion(auth, time.Now()); ok {
+		request.Header.Set("Authorization", assertion)
+	}
+	if auth != nil && auth.Metadata != nil {
+		if fedramp, ok := auth.Metadata["chatgpt_account_is_fedramp"].(bool); ok && fedramp {
+			request.Header.Set("X-OpenAI-Fedramp", "true")
+		}
+	}
+}
+
+func isCodexAgentIdentityTaskInvalid(statusCode int, body []byte) bool {
+	if statusCode != http.StatusUnauthorized {
+		return false
+	}
+	lower := strings.ToLower(string(body))
+	compact := strings.NewReplacer(" ", "", "\t", "", "\r", "", "\n", "").Replace(lower)
+	for _, marker := range []string{
+		`"code":"invalid_task_id"`,
+		`"code":"task_not_found"`,
+		`"code":"task_expired"`,
+		`"error":"invalid_task_id"`,
+	} {
+		if strings.Contains(compact, marker) {
+			return true
+		}
+	}
+	return false
+}
+
+func doCodexRequestWithAgentIdentityRecovery(
+	ctx context.Context,
+	client *http.Client,
+	request *http.Request,
+	auth *cliproxyauth.Auth,
+) (*http.Response, error) {
+	response, err := client.Do(request)
+	if err != nil || response == nil || !isCodexAgentIdentity(auth) || response.StatusCode != http.StatusUnauthorized {
+		return response, err
+	}
+	body, readErr := io.ReadAll(io.LimitReader(response.Body, codexAgentIdentityRequestLimit+1))
+	_ = response.Body.Close()
+	if readErr != nil {
+		return nil, errors.New("codex agent identity: failed to inspect unauthorized response")
+	}
+	if len(body) > codexAgentIdentityRequestLimit || !isCodexAgentIdentityTaskInvalid(response.StatusCode, body) || request.GetBody == nil {
+		response.Body = io.NopCloser(bytes.NewReader(body))
+		return response, nil
+	}
+	if err := codexAgentIdentityRegisterAndCache(ctx, auth, true); err != nil {
+		return nil, err
+	}
+	retryBody, err := request.GetBody()
+	if err != nil {
+		return nil, errors.New("codex agent identity: failed to replay request body")
+	}
+	retry := request.Clone(ctx)
+	retry.Body = retryBody
+	applyCodexAgentIdentityHeaders(retry, auth)
+	return client.Do(retry)
+}
