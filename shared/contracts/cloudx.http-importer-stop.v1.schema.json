{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudx.local/contracts/cloudx.http-importer-stop.v1.schema.json",
  "title": "Cloudx legacy HTTP importer stop transaction receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "releaseVersion",
    "releaseArtifact",
    "service",
    "previousPid",
    "listenerPort",
    "evidenceDigest",
    "rollbackSnapshot",
    "serviceActive",
    "serviceEnabled",
    "listenerClosed",
    "sshImportDryRunAccepted",
    "formalHealthAccepted",
    "phiConsumerAccepted",
    "gatewayModelAccepted",
    "gatewayProcessUnchanged",
    "selectorsUnchanged",
    "rollbackSnapshotRetained",
    "runtimeRemoved",
    "unitRemoved",
    "tokenRemoved",
    "failureReceiptsRemoved",
    "legacyExporterRetained",
    "gatewayRestarted",
    "phiServiceRestarted",
    "releaseActivated"
  ],
  "properties": {
    "schema": {"const": "cloudx.http-importer-stop.v1"},
    "status": {"const": "stopped"},
    "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "releaseArtifact": {"type": "string", "pattern": "^/opt/cloudx/releases/[0-9]+\\.[0-9]+\\.[0-9]+/cloudx-cloud\\.pyz$"},
    "service": {"const": "codex-import.service"},
    "previousPid": {"type": "integer", "minimum": 1},
    "listenerPort": {"const": 8780},
    "evidenceDigest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "rollbackSnapshot": {"type": "string", "pattern": "^/var/lib/cloudx/http-importer-stop-prep/[0-9]{8}T[0-9]{6}Z$"},
    "serviceActive": {"const": false},
    "serviceEnabled": {"const": false},
    "listenerClosed": {"const": true},
    "sshImportDryRunAccepted": {"const": true},
    "formalHealthAccepted": {"const": true},
    "phiConsumerAccepted": {"const": true},
    "gatewayModelAccepted": {"const": true},
    "gatewayProcessUnchanged": {"const": true},
    "selectorsUnchanged": {"const": true},
    "rollbackSnapshotRetained": {"const": true},
    "runtimeRemoved": {"const": false},
    "unitRemoved": {"const": false},
    "tokenRemoved": {"const": false},
    "failureReceiptsRemoved": {"const": false},
    "legacyExporterRetained": {"const": true},
    "gatewayRestarted": {"const": false},
    "phiServiceRestarted": {"const": false},
    "releaseActivated": {"const": false}
  }
}
